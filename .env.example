# Web3Forms — deprecated; contact form now sends via Zoho Mail API (/api/contact)
# VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Zoho CRM + Zoho Mail (contact form) — see docs/ZOHO-SETUP.md
# After changing scopes, re-run: npm run zoho:token -- --write
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.eu
ZOHO_API_DOMAIN=https://www.zohoapis.eu
ZOHO_CRM_LEAD_SOURCE=Website
ZOHO_MAIL_API_DOMAIN=https://mail.zoho.eu
# Optional: skip auto-discovery of the mailbox account ID
# ZOHO_MAIL_ACCOUNT_ID=
CONTACT_NOTIFY_EMAIL=info@nexaipla.com
CONTACT_FROM_EMAIL=info@nexaipla.com
CONTACT_EMAIL_SUBJECT=Επικοινωνία — NexAI
# Optional auto-reply subjects (defaults are bilingual EL/EN)
# CONTACT_AUTOREPLY_SUBJECT_EL=Ευχαριστούμε που επικοινωνήσατε με την NexAIpla
# CONTACT_AUTOREPLY_SUBJECT_EN=Thanks for contacting NexAIpla

# Optional: Zoho Flow webhook for extra automations (tasks, auto-reply, alerts)
ZOHO_FLOW_WEBHOOK_URL=

# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Food Order App demo origin (landing page "Try the demo" CTA links to {origin}/chat)
VITE_FOOD_ORDER_DEMO_ORIGIN=https://food-order-demo.vercel.app

# Shop Traffic demo dashboard origin (CTA links to {origin}/shop/{slug})
VITE_DASHBOARD_ORIGIN=https://live-traffic-dashboard.vercel.app

# Shop Traffic demo shop slug (path segment after /shop/)
VITE_DEMO_SHOP_SLUG=stellas-barber
